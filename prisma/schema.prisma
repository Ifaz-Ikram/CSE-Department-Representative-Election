generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model VoterRegistry {
  id          Int     @id @default(autoincrement())
  regNo       String  @unique   // e.g. "230253H"
  email       String  @unique   // e.g. "ifazi.23@cse.mrt.ac.lk"
  firstName   String
  lastName    String
  indexNumber String            // same as regNo
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  indexNumber   String?
  name          String
  role          String    @default("voter")
  createdAt     DateTime  @default(now())

  // NextAuth fields
  emailVerified DateTime?
  image         String?

  // Relations
  accounts      Account[]
  sessions      Session[]
  ballots       Ballot[]
  candidates    Candidate[]

  @@index([role])
  @@index([email, role])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Election {
  id                   String    @id @default(cuid())
  name                 String
  description          String?
  startTime            DateTime
  endTime              DateTime
  resultsVisible       Boolean   @default(false)
  publicResultsVisible Boolean   @default(false)
  resultsAutoEnabled   Boolean   @default(false)
  createdAt            DateTime  @default(now())

  candidates Candidate[]
  ballots    Ballot[]

  @@index([startTime, endTime])
  @@index([createdAt])
}

model Candidate {
  id           String        @id @default(cuid())
  electionId   String
  userId       String?
  name         String
  indexNumber  String
  email        String?
  bio          String?
  photoUrl     String?
  languages    String[]      @default([])

  election      Election      @relation(fields: [electionId], references: [id], onDelete: Cascade)
  user          User?         @relation(fields: [userId], references: [id])
  ballotChoices BallotChoice[]

  @@unique([electionId, userId], name: "unique_candidate_per_election")
  @@index([electionId])
  @@index([userId])
  @@index([email])
}

model Ballot {
  id         String       @id @default(cuid())
  electionId String
  voterId    String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  election Election @relation(fields: [electionId], references: [id], onDelete: Cascade)
  voter    User     @relation(fields: [voterId], references: [id], onDelete: Cascade)
  choices  BallotChoice[]

  @@unique([electionId, voterId])
  @@index([electionId])
  @@index([voterId])
  @@index([updatedAt])
  @@index([createdAt])
}

model BallotChoice {
  id          String    @id @default(cuid())
  ballotId    String
  candidateId String

  ballot    Ballot    @relation(fields: [ballotId], references: [id], onDelete: Cascade)
  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([ballotId, candidateId])
  @@index([ballotId])
  @@index([candidateId])
}

model AuditLog {
  id          String   @id @default(cuid())
  timestamp   DateTime @default(now())
  action      String   // e.g., "ELECTION_CREATED", "CANDIDATE_ADDED", "VOTE_CAST"
  category    String   // "ELECTION", "CANDIDATE", "VOTE", "AUTH"
  actorEmail  String   // Admin who performed the action (or "SYSTEM" for anonymous)
  actorRole   String   // "admin", "super_admin", or "voter"
  targetType  String?  // What was affected (Election, Candidate, etc.)
  targetId    String?  // ID of affected resource
  targetName  String?  // Human-readable name of target
  details     Json?    // Additional context (old/new values, metadata)

  @@index([timestamp])
  @@index([category])
  @@index([actorEmail])
  @@index([category, timestamp])
  @@index([targetId])
}
